void loadFromFile(vector<Contact>& contacts) {
    ifstream file("contacts.txt");
    if (!file.is_open()) return;

    string line;
    while (getline(file, line)) {
        stringstream ss(line);
        Contact c;
        getline(ss, c.name, ',');
        getline(ss, c.phone, ',');
        getline(ss, c.email, ',');
        contacts.push_back(c);
    }
}

void saveToFile(const vector<Contact>& contacts) {
    ofstream file("contacts.txt");
    for (const auto& c : contacts) {
        file << c.name << "," << c.phone << "," << c.email << "\n";
    }
}

void addContact(vector<Contact>& contacts) {
    Contact c;
    cout << YELLOW << "Name: " << RESET;
    cin >> ws;
    getline(cin, c.name);
    cout << YELLOW << "Phone: " << RESET;
    getline(cin, c.phone);
    cout << YELLOW << "Email: " << RESET;
    getline(cin, c.email);
    contacts.push_back(c);
    cout << GREEN << "Contact added.\n" << RESET;
}

void listContacts(const vector<Contact>& contacts) {
    if (contacts.empty()) {
        cout << RED << "No contacts.\n" << RESET;
        return;
    }
    cout << BLUE << "name:phone:email\n" << RESET;
    for (const auto& c : contacts) {
        cout << WHITE << c.name << " | " << c.phone << " | " << c.email << "\n" << RESET;
    }
}

